<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/activity_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal">

    <!-- Fragmento izquierdo: menú de navegación (30% del ancho) -->
    <FrameLayout
        android:id="@+id/contenedor_navegacion"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="3"
        android:background="@color/colorNavBackground" />

    <!-- Divisor vertical -->
    <View
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:background="@color/colorAccent" />

    <!-- Fragmento derecho: contenido dinámico (70% del ancho) -->
    <FrameLayout
        android:id="@+id/contenedor_contenido"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="7"
        android:background="@color/colorContentBackground" />

</LinearLayout>
