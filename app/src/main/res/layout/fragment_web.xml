<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorContentBackground">

    <!-- Barra de navegación web -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/colorPrimary"
        android:padding="8dp"
        android:gravity="center_vertical">

        <!-- Botón Atrás -->
        <Button
            android:id="@+id/btn_web_atras"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="←"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:backgroundTint="@color/colorPrimaryDark"
            android:padding="0dp"
            android:layout_marginEnd="4dp"/>

        <!-- Botón Adelante -->
        <Button
            android:id="@+id/btn_web_adelante"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="→"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:backgroundTint="@color/colorPrimaryDark"
            android:padding="0dp"
            android:layout_marginEnd="4dp"/>

        <!-- Botón Recargar -->
        <Button
            android:id="@+id/btn_web_recargar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="↺"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:backgroundTint="@color/colorPrimaryDark"
            android:padding="0dp"
            android:layout_marginEnd="8dp"/>

        <!-- Campo de URL -->
        <EditText
            android:id="@+id/et_url"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:hint="@string/web_hint"
            android:hintTextColor="#80FFFFFF"
            android:textColor="@color/white"
            android:background="@color/colorPrimaryDark"
            android:padding="8dp"
            android:textSize="12sp"
            android:inputType="textUri"
            android:imeOptions="actionGo"
            android:singleLine="true"
            android:layout_marginEnd="8dp"/>

        <!-- Botón IR -->
        <Button
            android:id="@+id/btn_web_ir"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/web_btn_ir"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:backgroundTint="@color/colorAccent"
            android:padding="8dp"/>

    </LinearLayout>

    <!-- Barra de progreso de carga -->
    <ProgressBar
        android:id="@+id/pb_carga_web"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:visibility="gone"
        android:progressTint="@color/colorAccent"/>

    <!-- WebView -->
    <WebView
        android:id="@+id/wv_navegador"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>
